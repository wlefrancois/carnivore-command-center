# Normalize text files
* text=auto

# Web/code files use LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Images/binaries
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary